extends _layout/layout

block variables
	- var title = 'Empire 360'
	- var description = 'Description for home page'
	- var bodyclass = 'home'
	- var href = "/index.html"

block body
	section.section-fullwidth
		//- #particles-js
		.background-slider
		.video-inner
			video.video-bg(preload='auto' loop='' autoplay='' muted='' playsinline='')
				source(type='video/mp4' src='./img/bg-7.mp4')
				source(type='video/webm' src='./img/bg-7.webm')
			noscript
				video.video-bg(preload='auto' loop autoplay muted playsinline)
					source(src='./img/bg-7.mp4' type='video/mp4')
					source(src='./img/bg-7.webm' type='video/webm')
		.welcomeblock
			//- h1 EMPIRE 360
			h1
				span EMPIRE 
					em 360
				span EMPIRE 
					em 360
				span EMPIRE 
					em 360
		.welcomeblock_sec
			h2 Brand Designers and Web Developers
		
		h3.text-rotate.text-rotate-create Creations
		h3.text-rotate.text-rotate-marketing Marketing 
		h3.text-rotate.text-rotate-website website
		a.linkdown(href='#portfolio')
			span(class='link__arrow')
				span
				span
			span(class='link__line')
			span(class='link__text') Projects

	section.section-services#about-us
		.background-slider
		.container-fluid
			.row.align-items-center
				.col-lg-6.order-lg-2
					.flit-animation.delay-0s(data-animation="fadeInUp")
						h2 
							span.text-main.text-text.font-weight-normal Empire 360 
							| 
							| the 
							| 
							span.tricker 
								em.text-sen.active Marketing Agency 
								em.text-sen Me, the second
								em.text-sen And I am the Third!
						h3.text-text Create Something Great
						.liner
					.flit-animation.faster(data-animation="fadeInUp")
						h4.text-muted who focus on delivering excellent creative marketing.
						p The 
							span.highlight highest
							| 
							| level of creative and 
							span.highlight professional 
							| 
							| engagement is what our crew brings to the brands we love. Branding, Website Design, Website Development, Social Media, Search Engine Optimization (SEO), Paid Search (PPC) and Video.
						p.lead We are ready to partner with you!
					p.flit-animation.fast(data-animation="fadeInUp") 
						a.btn.btn-call-to-action(href="#") Contact us

				.col-lg-6.order-lg-1.mt-5.mt-xl-0.pr-xl-5
					.pr-xl-5
						a(href="./img/brands.jpg" data-fancybox="images-flyer" data-caption="My caption")
							figure 
								img.img-fluid(src="./img/brands.jpg", alt="", srcset="") 
	section.section-plan#services
		.innetplan
			.container-fluid
				.row
					.col-lg-6
						h2 
							b.text-main This is
							| 
							| who
							| 
							span.text-white.text-shadow we are.
						h3 Dallas Fort Worth's best of class
						.liner
						.lead Sharing your brand-vision through beautiful web page design and website development for higher rankings and conversions.
				.row.mt-5
					.col-md-6.col-xl-3.mb-4
						h3.d-flex.align-items-center.item
							//- img(src="./img/circle-4.png", alt="", srcset="")
							span First we talk.
						p Communication is key to master development for your business.
					.col-md-6.col-xl-3.mb-4
						h3.d-flex.align-items-center.item
							//- //- img(src="./img/circle-4.png", alt="", srcset="")
							span Then we plan.
						p Inspiring creative fueled by exceptional web strategy.
					.col-md-6.col-xl-3.mb-4
						h3.d-flex.align-items-center.item
							//- //- img(src="./img/circle-4.png", alt="", srcset="")
							span Build and Launch.
						p Your story, beautifully designed for your website audience.
					.col-md-6.col-xl-3.mb-4
						h3.d-flex.align-items-center.item
							//- //- img(src="./img/circle-4.png", alt="", srcset="")
							span Adapt and Iterate.
						p Continue to learn, design and create based on good data.
